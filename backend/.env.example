# ============================================================
# JOE Cafeteria Backend - Environment Variables
# Copy this file to .env.local and fill in actual values
# ============================================================

NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/joe_cafeteria_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secrets (min 32 characters each)
JWT_SECRET=your-super-secure-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_EXPIRE_IN=1h
JWT_REFRESH_EXPIRE_IN=7d

# Firebase (for Google OAuth token verification)
FIREBASE_PROJECT_ID=joecafe-a7fff

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=razorpay_test_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# QR Code Encryption (exactly 32 characters for AES-256)
QR_ENCRYPTION_KEY=your-32-char-encryption-key-here

# Email Service (SendGrid)
SENDGRID_API_KEY=sg_xxxxxx

# Monitoring (Sentry)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
